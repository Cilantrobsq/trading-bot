{
  "version": "2.0",
  "status": "development",

  "risk_management": {
    "max_position_size_pct": 10,
    "max_single_theme_exposure_pct": 40,
    "stop_loss_pct": 8,
    "take_profit_pct": 20,
    "max_per_market_pct": 5,
    "max_per_event_category_pct": 15,
    "min_spread_after_fees_pct": 1.5,
    "kelly_fraction": 0.25
  },

  "polymarket": {
    "enabled": true,
    "api_base": "https://clob.polymarket.com",
    "data_api": "https://data-api.polymarket.com",
    "chain": "polygon",
    "fee_note": "Most markets 0% fee. 15-min crypto markets up to 3%. US DCM 0.10%"
  },

  "kalshi": {
    "enabled": false,
    "api_base": "https://trading-api.kalshi.com",
    "note": "Enable when Kalshi API access is set up"
  },

  "macro_signals": {
    "enabled": true,
    "fred_api_key_path": "secrets/fred.json",
    "indicators": [
      {"id": "DGS10", "name": "10Y Treasury Yield", "threshold_alert": 4.5},
      {"id": "DGS30", "name": "30Y Treasury Yield", "threshold_alert": 5.0},
      {"id": "MORTGAGE30US", "name": "30Y Mortgage Rate", "threshold_alert": 7.5},
      {"id": "VIXCLS", "name": "VIX Close", "threshold_alert": 25}
    ]
  },

  "data_sources": {
    "yfinance_tickers": [
      "__comment_indices__", "^GSPC", "^IXIC", "^DJI", "^RUT", "^VIX",
      "__comment_bonds__", "^TNX", "^TYX", "^FVX", "TLT", "SHY", "LQD", "HYG", "AGG",
      "__comment_sectors_us__", "XLK", "XLF", "XLE", "XLV", "XLI", "XLP", "XLU", "XLY", "XLB", "XLRE", "XLC",
      "__comment_mega_tech__", "AAPL", "MSFT", "GOOGL", "AMZN", "NVDA", "META", "TSLA", "AMD", "AVGO", "CRM",
      "__comment_ai_semis__", "SMCI", "ARM", "MRVL", "INTC", "QCOM", "MU", "TSM",
      "__comment_crypto_equities__", "MSTR", "COIN", "MARA", "RIOT", "CLSK", "HUT",
      "__comment_commodities__", "GC=F", "SI=F", "CL=F", "BZ=F", "NG=F", "HG=F", "ZW=F", "ZC=F",
      "__comment_commodity_etfs__", "GLD", "SLV", "USO", "UNG", "DBA",
      "__comment_emerging__", "EEM", "FXI", "EWZ", "INDA", "EWY", "EWT",
      "__comment_forex__", "EURUSD=X", "GBPUSD=X", "USDJPY=X", "USDCNH=X", "AUDUSD=X", "DX-Y.NYB",
      "__comment_crypto__", "BTC-USD", "ETH-USD", "SOL-USD", "XRP-USD", "ADA-USD", "DOGE-USD", "AVAX-USD", "DOT-USD", "LINK-USD", "MATIC-USD", "UNI-USD", "AAVE-USD", "BNB-USD", "NEAR-USD", "ARB11841-USD", "OP-USD", "ATOM-USD", "FIL-USD", "LTC-USD", "BCH-USD",
      "__comment_defense_energy__", "ITA", "LMT", "RTX", "XOM", "CVX", "OXY",
      "__comment_housing__", "XHB", "ITB", "VNQ", "O", "LEN", "DHI",
      "__comment_europe__", "MEL.MC", "IAG.L", "TUI1.DE", "MRL.MC"
    ],
    "news_feeds": [
      "__comment_macro__",
      "https://news.google.com/rss/search?q=federal+reserve+interest+rates",
      "https://news.google.com/rss/search?q=ECB+monetary+policy",
      "https://news.google.com/rss/search?q=bank+of+japan+policy",
      "https://news.google.com/rss/search?q=inflation+CPI+data",
      "https://news.google.com/rss/search?q=treasury+yields+bonds",
      "https://news.google.com/rss/search?q=recession+economic+downturn",

      "__comment_crypto__",
      "https://news.google.com/rss/search?q=bitcoin+BTC+price",
      "https://news.google.com/rss/search?q=ethereum+ETH+DeFi",
      "https://news.google.com/rss/search?q=crypto+regulation+SEC",
      "https://news.google.com/rss/search?q=crypto+ETF+institutional",
      "https://news.google.com/rss/search?q=stablecoin+USDT+USDC",
      "https://news.google.com/rss/search?q=solana+altcoin+rally",

      "__comment_tech_ai__",
      "https://news.google.com/rss/search?q=nvidia+AI+chips",
      "https://news.google.com/rss/search?q=artificial+intelligence+investment",
      "https://news.google.com/rss/search?q=big+tech+earnings+results",
      "https://news.google.com/rss/search?q=semiconductor+chip+shortage",

      "__comment_geopolitics__",
      "https://news.google.com/rss/search?q=US+China+trade+war+tariffs",
      "https://news.google.com/rss/search?q=Ukraine+Russia+war+NATO",
      "https://news.google.com/rss/search?q=Middle+East+conflict+oil",
      "https://news.google.com/rss/search?q=Taiwan+strait+tensions",
      "https://news.google.com/rss/search?q=sanctions+geopolitical+risk",

      "__comment_commodities__",
      "https://news.google.com/rss/search?q=oil+price+OPEC+production",
      "https://news.google.com/rss/search?q=gold+price+safe+haven",
      "https://news.google.com/rss/search?q=copper+commodities+demand",

      "__comment_markets_general__",
      "https://news.google.com/rss/search?q=stock+market+crash+correction",
      "https://news.google.com/rss/search?q=IPO+market+SPAC",
      "https://news.google.com/rss/search?q=short+squeeze+meme+stock",
      "https://news.google.com/rss/search?q=hedge+fund+positioning",

      "__comment_prediction_markets__",
      "https://news.google.com/rss/search?q=polymarket+prediction+market",
      "https://news.google.com/rss/search?q=kalshi+event+contracts",

      "__comment_global__",
      "https://news.google.com/rss/search?q=emerging+markets+crisis",
      "https://news.google.com/rss/search?q=Japan+economy+yen",
      "https://news.google.com/rss/search?q=China+economy+property",
      "https://news.google.com/rss/search?q=India+economy+growth",
      "https://news.google.com/rss/search?q=European+economy+outlook"
    ]
  },

  "fred_api": {
    "series": [
      {"id": "DGS10",       "name": "10Y Treasury Yield",      "threshold": 4.5,  "direction": "rising"},
      {"id": "DGS30",       "name": "30Y Treasury Yield",      "threshold": 5.0,  "direction": "rising"},
      {"id": "MORTGAGE30US","name": "30Y Mortgage Rate",        "threshold": 7.5,  "direction": "rising"},
      {"id": "T10Y2Y",      "name": "10Y-2Y Yield Curve",      "threshold": -0.2, "direction": "falling"},
      {"id": "VIXCLS",      "name": "VIX Close",               "threshold": 25.0, "direction": "rising"},
      {"id": "UNRATE",      "name": "Unemployment Rate",        "threshold": 5.0,  "direction": "rising"},
      {"id": "CPIAUCSL",    "name": "CPI All Urban Consumers",  "threshold": null, "direction": "rising"},
      {"id": "FEDFUNDS",    "name": "Federal Funds Rate",       "threshold": 5.5,  "direction": "rising"},
      {"id": "GDP",         "name": "Gross Domestic Product",    "threshold": null, "direction": "falling"},
      {"id": "UMCSENT",     "name": "Consumer Sentiment",       "threshold": 60.0, "direction": "falling"},
      {"id": "T10Y3M",     "name": "10Y-3M Yield Curve",      "threshold": -0.5, "direction": "falling"},
      {"id": "STLFSI4",    "name": "Financial Stress Index",    "threshold": 1.5,  "direction": "rising"},
      {"id": "BAMLH0A0HYM2","name": "HY Credit Spread",        "threshold": 5.0,  "direction": "rising"},
      {"id": "ICSA",       "name": "Weekly Jobless Claims",     "threshold": 300000, "direction": "rising"},
      {"id": "M2SL",       "name": "M2 Money Supply",           "threshold": null, "direction": "falling"},
      {"id": "DTWEXBGS",   "name": "Trade-Weighted USD Index",  "threshold": 130.0, "direction": "rising"}
    ]
  },

  "finnhub": {
    "tickers": ["AAPL", "TSLA", "SPY", "NVDA", "MSFT", "GOOGL", "AMZN", "META", "AMD", "COIN"],
    "crypto_symbols": ["BTC", "ETH", "SOL", "XRP", "ADA", "DOGE", "AVAX", "DOT"]
  },

  "llm_analysis": {
    "model": "claude-haiku-4-5-20251001",
    "max_batch_size": 20,
    "max_daily_calls": 100
  },

  "prediction_markets": {
    "platforms": ["polymarket", "manifold", "metaculus"],
    "arbitrage_threshold_pct": 5.0,
    "max_markets_per_platform": 50
  },

  "paper_trading": {
    "enabled": true,
    "initial_balance_usd": 10000,
    "note": "Paper trading mode. Set enabled=false and add real credentials to go live."
  }
}
